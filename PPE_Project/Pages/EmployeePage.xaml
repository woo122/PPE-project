<Page x:Class="PPE_Project.Pages.EmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PPE_Project.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StatsPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽: 사원 리스트 -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="사원 목록" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListView x:Name="EmployeeListView" SelectionChanged="EmployeeListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="이름" Width="100" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="직급" Width="100" DisplayMemberBinding="{Binding Position}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>

        <!-- 오른쪽: 얼굴 사진 + 카메라 + 입력 + 버튼 -->
        <StackPanel Grid.Column="1" Margin="20" Orientation="Horizontal">

            <!-- 카메라 영상 -->
            <Border Width="250" Height="300" Background="Black" HorizontalAlignment="Left">
                <Image x:Name="CameraView" Stretch="Uniform"/>
            </Border>

            <StackPanel VerticalAlignment="Center" Margin="20" HorizontalAlignment="Center">
                <!-- 캡처된 얼굴 사진 -->
                <Border Width="100" Height="100" Background="LightGray" Margin="0,10,0,0">
                    <Image x:Name="FaceImage" Stretch="Uniform"/>
                </Border>

                <Button Content="얼굴 캡처" Width="200" Margin="0,10,0,0" Click="btn_Capture_Click"/>

                <TextBlock Text="이름" Margin="30,10,0,5"/>
                <TextBox x:Name="NameTextBox" Width="200"/>

                <TextBlock Text="직급" Margin="30,10,0,5"/>
                <TextBox x:Name="PositionTextBox" Width="200" />

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="등록" Width="80" Margin="0,0,10,0" Click="btn_Add_Click"/>
                    <Button Content="수정" Width="80" Margin="0,0,10,0" Click="btn_Update_Click"/>
                    <Button Content="삭제" Width="80" Click="btn_Delete_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
