<Page x:Class="PPE_Project.Pages.RecordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="출퇴근 기록">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 상단 검색 -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="10,5">
            <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="SearchBox" Width="200" VerticalAlignment="Center" TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <!-- 왼쪽: 출퇴근 기록 리스트 -->
        <ListView Grid.Row="1" Grid.Column="0" x:Name="RecordListView" Margin="10" SelectionChanged="RecordListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="이름" Width="60" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="직급" Width="60" DisplayMemberBinding="{Binding Position}"/>
                    <GridViewColumn Header="날짜" Width="90" DisplayMemberBinding="{Binding Date}"/>
                    <GridViewColumn Header="시간" Width="80" DisplayMemberBinding="{Binding Time}"/>
                    <GridViewColumn Header="상태" Width="60" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="안전장비" Width="90" DisplayMemberBinding="{Binding PPEStatus}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 오른쪽: 통계 -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
            <TextBlock x:Name="StatTitle" Text="사원을 선택하세요" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="이번달 출근 일수" FontSize="20" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBlock x:Name="AttendanceDays" Text="-" FontSize="24" FontWeight="Bold" Foreground="SteelBlue" Margin="0,0,0,20"/>

            <TextBlock Text="안전장비 착용률" FontSize="20" Margin="0,0,0,10" FontWeight="Bold"/>
            <lvc:PieChart x:Name="PPEChart" Height="200" Width="200" Margin="0,20,0,0" 
                          HorizontalAlignment="Left"
                          LegendPosition="Bottom"
                          AnimationsSpeed="00:00:00"/>
        </StackPanel>
    </Grid>
</Page>